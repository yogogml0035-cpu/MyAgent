# Backend-only secrets. Do not expose these values to the frontend.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Local web search engine. Defaults to http://127.0.0.1:8181/ when unset.
MYAGENT_SEARXNG_URL=http://127.0.0.1:8181/

# Required production storage and memory services.
MYAGENT_DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DBNAME
MYAGENT_QDRANT_URL=http://127.0.0.1:6333
DASHSCOPE_API_KEY=
MYAGENT_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MYAGENT_EMBEDDING_MODEL=text-embedding-v3
MYAGENT_EMBEDDING_DIMENSIONS=1024
MYAGENT_QDRANT_COLLECTION=myagent_memories
MYAGENT_DEFAULT_USER_ID=local-user
MYAGENT_FRESH_TOOL_CACHE_SECONDS=600
MYAGENT_RECENT_MESSAGE_LIMIT=12
MYAGENT_MEMORY_MIN_SCORE=0.72

# Optional. When set, task APIs require this value as either:
# Authorization: Bearer <token> or X-MyAgent-Token: <token>.
MYAGENT_ACCESS_TOKEN=

# Comma-separated browser origins allowed to call the backend.
# Add LAN origins such as http://<LAN_IP>:3001 when exposing the frontend by IP.
MYAGENT_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Optional override. Defaults to ./storage/sessions under this backend directory.
MYAGENT_TASK_ROOT=

# Optional safety limits.
MYAGENT_MAX_UPLOAD_FILES=10
MYAGENT_MAX_UPLOAD_FILE_BYTES=10485760
MYAGENT_MAX_UPLOAD_REQUEST_BYTES=105906176
MYAGENT_MAX_JSON_REQUEST_BYTES=65536
