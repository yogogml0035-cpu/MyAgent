# Backend-only secrets. Do not expose these values to the frontend.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
TAVILY_API_KEY=

# Optional. When set, task APIs require this value as either:
# Authorization: Bearer <token> or X-MyAgent-Token: <token>.
MYAGENT_ACCESS_TOKEN=

# Comma-separated browser origins allowed to call the backend.
# Add LAN origins such as http://10.11.148.97:3000 when exposing the frontend by IP.
MYAGENT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional override. Defaults to ./storage/tasks under this backend directory.
MYAGENT_TASK_ROOT=

# Optional safety limits.
MYAGENT_MAX_UPLOAD_FILES=10
MYAGENT_MAX_UPLOAD_FILE_BYTES=10485760
MYAGENT_MAX_UPLOAD_REQUEST_BYTES=105906176
MYAGENT_MAX_JSON_REQUEST_BYTES=65536
DEEPSEEK_TIMEOUT_SECONDS=15
