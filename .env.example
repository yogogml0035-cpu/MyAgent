# MyAgent environment reference.
#
# Runtime env files are split by service:
# - Copy the backend section to backend/.env.
# - Copy the frontend section to frontend/.env.local when local defaults are not enough.
#
# Do not put provider API keys or other secrets in NEXT_PUBLIC_* values.

# Backend-only secrets and runtime settings.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
TAVILY_API_KEY=

# Optional. When set, task APIs require this value as either:
# Authorization: Bearer <token> or X-MyAgent-Token: <token>.
MYAGENT_ACCESS_TOKEN=

# Optional override. Defaults to backend/storage/tasks.
MYAGENT_TASK_ROOT=

# Optional safety limits.
MYAGENT_MAX_UPLOAD_FILES=10
MYAGENT_MAX_UPLOAD_FILE_BYTES=10485760
MYAGENT_MAX_UPLOAD_REQUEST_BYTES=105906176
MYAGENT_MAX_JSON_REQUEST_BYTES=65536
DEEPSEEK_TIMEOUT_SECONDS=15

# Frontend public values. These are browser-visible.
NEXT_PUBLIC_MYAGENT_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MYAGENT_TOKEN=
